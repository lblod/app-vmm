skos:prefLabel rdfs:subPropertyOf <http://schema.org/name> .

skos:notation rdfs:subPropertyOf <http://schema.org/identifier> .

skos:historyNote rdfs:subPropertyOf <http://schema.org/version> .

ns3:isSeriesOf rdfs:subPropertyOf skos:broader;
  rdfs:domain ns3:Series;
  rdfs:range ns3:Indicator;
  rdfs:label "is series of"@en .

ns3:isIndicatorOf rdfs:subPropertyOf skos:broader;
  rdfs:domain ns3:Indicator;
  rdfs:range ns3:Target;
  rdfs:label "is indicator of"@en .

ns3:hasSeries rdfs:subPropertyOf skos:narrower;
  rdfs:domain ns3:Indicator;
  rdfs:range ns3:Series;
  rdfs:label "has series"@en .

ns3:hasIndicator rdfs:subPropertyOf skos:narrower;
  rdfs:domain ns3:Target;
  rdfs:range ns3:Indicator;
  rdfs:label "has indicator"@en .

ns3:hasTarget rdfs:subPropertyOf skos:narrower;
  rdfs:domain ns3:Goal;
  rdfs:range ns3:Target;
  rdfs:label "has target"@en .

ns3:isTargetOf rdfs:subPropertyOf skos:broader;
  rdfs:domain ns3:Target;
  rdfs:range ns3:Goal;
  rdfs:label "is target of"@en .

ns3:Series rdfs:subClassOf skos:Concept, <http://schema.org/Dataset>;
  rdfs:label "Series"@en .

ns3:Indicator rdfs:subClassOf skos:Concept;
  rdfs:label "Indicator"@en, "Indicador"@es, "Indicateur"@fr .

ns3:Target rdfs:subClassOf skos:Concept;
  rdfs:label "Target"@en, "Meta"@es, "Cible"@fr .

ns3:Goal rdfs:subClassOf skos:Concept;
  rdfs:label "Goal"@en, "Objetivo"@es, "Objectif"@fr .

dct:subject rdfs:domain skos:Concept;
  rdfs:range skos:Concept .

ns3:tier rdfs:domain ns3:Indicator;
  rdfs:range ns3:Tier;
  rdfs:label "tier"@en .

ns3:custodianAgency rdfs:domain ns3:Indicator;
  rdfs:range xsd:string;
  rdfs:label "has custodian agency"@en .

ns3:tier_III rdfs:isDefinedBy <https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification>;
  owl:deprecated false .

ns3:tier_II rdfs:isDefinedBy <https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification>;
  owl:deprecated false .

ns3:tier_I rdfs:isDefinedBy <https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification>;
  owl:deprecated false .

ns3:SDGCode rdfs:label "Standard SDG code"@en .

ns3:SDGCodeCompact rdfs:label "Standard SDG code in the compact format"@en .

ns3:SDGCodePerm rdfs:label "Permanent SDG indicator code"@en .

<http://metadata.un.org/sdg/ontology> rdfs:label "Sustainable Development Goals Ontology"@en .

ns3:Tier rdfs:label "Tier Classification for Global SDG Indicators"@en .



@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix mu: <http://mu.semte.ch/vocabularies/core#> .

<http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> a skos:ConceptScheme ;
    mu:uuid "96668f64-2863-435a-a300-3e66efc0f84b" ;
    skos:prefLabel "Types van beperkte mobiliteitszones"@nl ;
    skos:prefLabel "Types of restricted mobility zones"@en ;
    skos:definition """Beperkte mobiliteitszones zijn types van locaties waar er impact is op de mobiliteit van bepaalde doelgroepen en waarover er besluitvorming gevoerd is door een overheid. 
                    Impact kan beperkend zijn zoals bij innames openbaar domein, mobiliteitshinder of bepaalde reglementen (aanvullend, tijdelijk, autoluwe zones, lage emissiezones). Impact kan ook car(e) free betekenen voor bepaalde doelgroepen (speelstraten, fietstraten, autoluwe gebieden)."""@nl ;
    skos:definition """Restricted mobility zones are types of locations where there is an impact on the mobility of certain target groups and where decision-making has been carried out by a government. 
                    Impact can be restrictive such as with public domain occupancy, mobility hindrance or certain regulations (complementary, temporary, car-free zones, low emission zones). Impact can also mean car(e) free for certain target groups (play streets, bicycle streets, pedestrian areas)."""@en .

# -------------------------------
# Zone types die in reglementen voorkomen
# -------------------------------

<https://data.vlaanderen.be/id/concept/ZoneType/dea804b7-b4b1-47c3-8438-40a04be013c7>
  a skos:Concept ;
  mu:uuid "dea804b7-b4b1-47c3-8438-40a04be013c7" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een geografisch gedefinieerd gebied waar toegang wordt beperkt op basis van de emissiestandaard van voertuigen."@nl;
  skos:definition "A geographically defined area where access is restricted based on vehicle emission standards."@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Lage Emissie Zone (LEZ)"@nl;
  skos:prefLabel "Low Emission Zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/efc8d1ed-61b0-4bbb-8811-def871a6367b>
  a skos:Concept ;
  mu:uuid "efc8d1ed-61b0-4bbb-8811-def871a6367b" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een geografisch gedefinieerd gebied waar toegang wordt beperkt op basis van de emissiestandaard van voertuigen."@nl;
  skos:definition "A geographically defined area where access is restricted based on vehicle emission standards."@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Zero Emissie Zone (ZEZ)"@nl;
  skos:prefLabel "Zero Emission Zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/bf79aa98-a214-4aee-a915-5328b0b05c07>
  a skos:Concept ;
  mu:uuid "bf79aa98-a214-4aee-a915-5328b0b05c07" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een zone waarvoor voetgangers prioriteit hebben en motorvoertuigen verboden of sterk beperkt zijn (bijvoorbeeld alleen toegang voor gemachtigden binnen bepaalde uren)"@nl;
  skos:definition "A zone prioritised for pedestrians where motorised traffic is prohibited or heavily restricted (eg. only access to permit holders between certain hours)"@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Autoluwe zone"@nl;
  skos:prefLabel "Car-free zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/c463f4ff-6453-43dc-8266-0c4af80d5b10>
  a skos:Concept ;
  mu:uuid "c463f4ff-6453-43dc-8266-0c4af80d5b10" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een zone waarvoor voetgangers prioriteit hebben en motorvoertuigen verboden of sterk beperkt zijn (bijvoorbeeld alleen toegang voor gemachtigden binnen bepaalde uren)"@nl;
  skos:definition "A zone prioritised for pedestrians where motorised traffic is prohibited or heavily restricted (eg. only access to permit holders between certain hours)"@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Voetgangerszone"@nl;
  skos:prefLabel "Pedestrian zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/3c95845d-b5fd-47a4-a784-b99f081f5bc4>
  a skos:Concept ;
  mu:uuid "3c95845d-b5fd-47a4-a784-b99f081f5bc4" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een straat of zone ontworpen als een sociaal gebied voor voetgangers en fietsers; motorvoertuigen zijn toegestaan, maar beperkt"@nl;
  skos:definition "A street/zone designed as a social space for pedestrians and cyclists; motorized transport is permitted, but limited"@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Woonerf"@nl;
  skos:prefLabel "Home zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/502c3398-4842-4408-9543-574bd9c31b36>
  a skos:Concept ;
  mu:uuid "502c3398-4842-4408-9543-574bd9c31b36" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een straat waar fietsers prioriteit hebben en motorvoertuigen subordineerd of beperkt zijn."@nl;
  skos:definition "A street where cyclists have priority and motor vehicles are subordinated or restricted."@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Fietszone"@nl;
  skos:prefLabel "Bicycle zone"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/8cc0caf8-2789-4191-bd40-05d5749714cf>
  a skos:Concept ;
  mu:uuid "8cc0caf8-2789-4191-bd40-05d5749714cf" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een straat tijdelijk beperkt tot motorvoertuigen tijdens school drop-off en pick-up uren."@nl;
  skos:definition "A street temporarily restricted to motorised traffic during school drop-off and pick-up hours."@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Schoolstraat"@nl;
  skos:prefLabel "School street"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

<https://data.vlaanderen.be/id/concept/ZoneType/6b94b24b-b308-4366-bf1b-cb6f69b93596>
  a skos:Concept ;
  mu:uuid "6b94b24b-b308-4366-bf1b-cb6f69b93596" ;
  <http://www.w3.org/2002/07/owl#deprecated> false;
  skos:definition "Een inname openbaar domein waarbij een parkeerplaats gereserveerd is voor een andere doeleinde (zoals containers, verhuizing, enz.)"@nl;
  skos:definition "Occupancy in which a parking space is reserved for another purpose (such as containers, moving, etc.)"@en;
  skos:inScheme <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types>;
  skos:prefLabel "Parkeerverbod"@nl;
  skos:prefLabel "Reserved parking space"@en;
  skos:topConceptOf <http://data.lblod.gift/id/conceptscheme/restricted-mobility-zone-types> .

